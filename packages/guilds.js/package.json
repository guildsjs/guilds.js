{
    "name": "guilds.js",
    "description": "Node.js library for using Discord's API and gateway",
    "homepage": "https://guilds.js.org",
    "version": "1.0.0",
    "license": "UNLICENSED",
    "scripts": {
        "build": "tsdown",
        "format": "prettier --write . --config ../../package.json --ignore-path ../../.prettierignore",
        "lint": "tsc --noEmit; prettier --check . --config ../../package.json --ignore-path ../../.prettierignore",
        "prepublish": "tsdown",
        "postbuild": "node -e \"const fs=require('fs');const v=require('./package.json').version;fs.appendFileSync('dist/index.cjs','\\nexports.version = \\\"'+v+'\\\";\\n');fs.appendFileSync('dist/index.d.cts','\\nexport declare const version = \\\"'+v+'\\\";\\n');\""
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "exports": "./dist/index.cjs",
    "repository": {
        "type": "git",
        "url": "https://github.com/guildsjs/guilds.js"
    },
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "prettier": "^3.8.1",
        "tsdown": "^0.20.3",
        "typescript": "^5.9.3"
    },
    "files": [
        "dist",
        "LICENSE",
        "package.json",
        "README.md"
    ],
    "keywords": [
        "api",
        "discord",
        "discord-bot",
        "javascript",
        "library",
        "module",
        "node",
        "node-js",
        "npm",
        "pnpm",
        "tsdown",
        "typescript",
        "websocket",
        "ws"
    ],
    "engines": {
        "node": ">=22"
    }
}
